[gd_scene format=3 uid="uid://dmbu7pqwj0jqn"]

[sub_resource type="GDScript" id="GDScript_y18dx"]
resource_name = "renderer"
script/source = "@tool
extends SubViewport

@onready var CameraRoot := $Node3D
@onready var Camera := $Node3D/Camera3D

@export_category(\"Multiple Shoot\")
@export_global_dir var SaveDir := \"\"
@export var FileNamePrefix := \"\"
@export var Times := 1
@export_tool_button(\"Shoot\")
var MultiShoot := func():
	if Times <= 1:
		var curent_angle = CameraAngle
		CameraAngle = AngleFrom
		take_shoot().save_png(SaveDir+\"/\"+FileNamePrefix+\".png\")
		CameraAngle = curent_angle
		return
	
	var current_angle = CameraAngle
	for i in Times:
		var angle = lerpf(AngleFrom, AngleTo, float(i)/(Times-1))
		CameraAngle = angle
		await get_tree().process_frame
		if i == 0: await get_tree().process_frame
		take_shoot().save_png(SaveDir+\"/\"+FileNamePrefix+( \"%06.2f\" % angle)+\".png\")
	CameraAngle = current_angle
	pass
@export_range(0, 180, 0.5) var AngleFrom := 0.0
@export_range(0, 180, 0.5) var AngleTo := 0.0


@export_category(\"Single Shoot\")
@export_custom(PROPERTY_HINT_GLOBAL_SAVE_FILE, \"*.png\") var FileName := \"\"
@export_tool_button(\"Shoot\")
var Shoot := func():
	take_shoot().save_png(FileName)
	pass


@export_category(\"State\")

@export_exp_easing() var CameraDistance := 5.0:
	get(): return Camera.position.z
	set(value):
		(func():
			Camera.position.z = value
		).call_deferred()

@export_range(0, 180, 0.5) var CameraAngle := 0.0:
	get(): return -CameraRoot.rotation_degrees.x
	set(value):
		if CameraRoot == null:
			(func():
				CameraRoot.rotation_degrees.x = -value
			).call_deferred()
		else:
			CameraRoot.rotation_degrees.x = -value

@export_range(-180, 180, 0.5) var CameraTanAngle := 0.0:
	get(): return CameraRoot.rotation_degrees.z
	set(value):
		(func():
			CameraRoot.rotation_degrees.z = value
			Camera.rotation_degrees.z = -value
		).call_deferred()

@export_range(1, 179, 0.1) var CameraFov := 75.0:
	get(): return Camera.fov
	set(value):
		(func():
			Camera.fov = value
		).call_deferred()


func take_shoot() -> Image:
	return get_texture().get_image()
"

