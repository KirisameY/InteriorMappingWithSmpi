void vertex() {
	// Called for every vertex the material is visible on.
	UV *= vec2(1, -1);
	UV += uv_offset;
	UV *= uv_scale;
	UV *= origin_size;
	
	// 切线空间变换
	vec3 cam_pos_model = (inverse(MODEL_MATRIX) * INV_VIEW_MATRIX * vec4(0.0, 0.0, 0.0, 1.0)).xyz;
	vec3 view_dir_model = VERTEX - cam_pos_model;
	vec3 t = normalize(TANGENT);
	vec3 b = normalize(BINORMAL);
	vec3 n = normalize(NORMAL);
	
	view_dir = vec3(
		dot(view_dir_model, t),
		dot(view_dir_model, b),
		dot(view_dir_model, n)
	);
}

void fragment() {
	// Called for every pixel the material is visible on.
	
	vec3 vd = normalize(view_dir);
	vec3 org = vec3(mod(UV, origin_size) - origin_size/2., 0);
	
	#define N 24
	
	vec4[N] colors;
	float[N] depths;
	float[N] oalphas;
	for (int i = 0; i < N; i++)
	{
		// t = (P - O) · N / (D · N)
		float t = dot(planes_o[i] - org, planes_n[i]) / dot(vd, planes_n[i]);
		vec3 pos = org + vd * t;
		vec3 pos_p = pos - planes_o[i];
		float u = dot(pos_p, planes_u[i]) / dot(planes_u[i], planes_u[i]);
		float v = dot(pos_p, planes_v[i]) / dot(planes_v[i], planes_v[i]);
		vec2 uv = vec2(u, v);
		
		vec4 current = texture(texs, vec3(uv + vec2(.5), float(i)));
		current *= step(abs(u), 0.5) * step(abs(v), 0.5) * step(0, t);
		float oa = current.a;
		for(int j = 0; j < i; j++)
		{
			float dd = step(depths[j], t);
			colors[j].a *= dd + (1. - dd) * (1. - oa);
			current.a *= dd * (1. - oalphas[j]) + (1. - dd);
		}
		
		colors[i] = current;
		depths[i] = t;
		oalphas[i] = oa;
	}
	
	vec3 final_color = vec3(0);
	for (int j = 0; j < N; j++) // 遍历颜色并混合
	{
		final_color += colors[j].rgb * colors[j].a;
	}
	
	ALBEDO = final_color;
}

