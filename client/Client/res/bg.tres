[gd_resource type="ShaderMaterial" format=3 uid="uid://doauyv43qcpru"]

[sub_resource type="Shader" id="Shader_2qxv5"]
code = "shader_type spatial;
render_mode unshaded, cull_front;

instance uniform vec2 size;

void vertex() {
	// Called for every vertex the material is visible on.
}

void fragment() {
	ALBEDO = vec3(0);
	vec4 pos4 = INV_VIEW_MATRIX * vec4(VERTEX,1.);
	vec3 pos = pos4.xyz / pos4.w;
	ALPHA *= 1. - step(abs(pos.x), size.x/2.) * step(abs(pos.y), size.y/2.);
}

//void light() {
//	// Called for every pixel for every light affecting the material.
//	// Uncomment to replace the default light processing function with this one.
//}
"

[resource]
render_priority = 0
shader = SubResource("Shader_2qxv5")
